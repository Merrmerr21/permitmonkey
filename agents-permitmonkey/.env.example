# PermitMonkey agents (Claude Agent SDK runners)
#
# Copy this file to .env for local CLI runs (npm run dev, eval fixtures via
# server/evals/runner.ts subprocess bridge). In production, the Cloud Run
# orchestrator passes these values through to the spawned agent process.

# Read by the Agent SDK directly; no explicit lookup in src/ but required at runtime.
ANTHROPIC_API_KEY=

# Optional: 'debug' | 'info' | 'warn' | 'error'. Defaults to 'info' if unset.
LOG_LEVEL=info
