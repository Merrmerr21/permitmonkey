# PermitMonkey frontend (Next.js 16 on Vercel)
#
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored; .env.example (this file) is committed as the schema.

# Supabase — browser-safe (used in 'use client' code paths)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase — server-only. Never import into a 'use client' file.
# Used by lib/api-auth.ts to verify session ownership before proxying to Cloud Run.
SUPABASE_SERVICE_ROLE_KEY=

# Cloud Run orchestrator URL (Express 5 service). Frontend proxies /api/extract
# and /api/generate here. In dev, point at http://localhost:8080.
CLOUD_RUN_URL=

# Shared secret between Vercel functions and Cloud Run. Rotate quarterly.
PERMITMONKEY_API_KEY=
