# PermitMonkey orchestrator (Express 5 on Cloud Run)
#
# Copy this file to .env and fill in real values for local development.
# Production values are stored in GCP Secret Manager and injected by
# .github/workflows/deploy-server.yml.

# Anthropic API — used by the Agent SDK runs spawned in Vercel Sandbox.
ANTHROPIC_API_KEY=

# Supabase — service-role. Server-only. Never expose to the frontend.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Vercel Sandbox — required to spin up isolated agent execution environments.
# All three are needed; missing any fails sandbox creation at runtime.
VERCEL_TEAM_ID=
VERCEL_PROJECT_ID=
VERCEL_TOKEN=

# HTTP listener. Cloud Run sets PORT=8080 automatically; override only for local.
PORT=8080
